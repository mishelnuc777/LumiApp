rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny - Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() >= 3 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // --- Entity Validations ---
    function isValidUser(data) {
      return data.userId == request.auth.uid
        && data.pseudonym is string && data.pseudonym.size() >= 3 && data.pseudonym.size() <= 40
        && data.avatarUrl is string && data.avatarUrl.size() <= 500;
    }

    function isValidPost(data) {
      return data.authorId == request.auth.uid
        && data.title is string && data.title.size() >= 3 && data.title.size() <= 300
        && data.content is string && data.content.size() <= 10000
        && data.authorPseudonym is string
        && data.createdAt == request.time;
    }

    function isValidComment(data) {
      return data.authorId == request.auth.uid
        && data.content is string && data.content.size() >= 1 && data.content.size() <= 2000
        && data.createdAt == request.time;
    }

    // --- Rules ---

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid; // Secure list
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) 
        && isValidUser(incoming())
        && incoming().diff(existing()).affectedKeys().hasOnly(['pseudonym', 'displayName', 'avatarUrl', 'bio', 'savedPosts']);
    }

    match /communities/{communityId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidId(communityId);
    }

    match /posts/{postId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidId(postId) && isValidPost(incoming());
      allow update: if isSignedIn() && (
        // Action: Edit
        (isOwner(existing().authorId) && incoming().diff(existing()).affectedKeys().hasOnly(['title', 'content', 'updatedAt']) && incoming().updatedAt == request.time) ||
        // Action: Reaction / Metadata
        (incoming().diff(existing()).affectedKeys().hasOnly(['upvotes', 'downvotes', 'score', 'commentCount', 'medicalFlag']))
      );
      allow delete: if isOwner(existing().authorId);

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn() && isValidComment(incoming());
        allow update: if isOwner(existing().authorId) 
          && incoming().diff(existing()).affectedKeys().hasOnly(['content', 'updatedAt'])
          && incoming().updatedAt == request.time;
      }
    }

    match /votes/{voteId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update: if false; // Votes are typically deleted and recreated or toggled
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
  }
}
